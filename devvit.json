{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tiny-tacticians",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "asUser": [
        "SUBMIT_POST"
      ]
    },
    "redis": true
  },
  "menu": {
    "items": [
      {
        "label": "Crear post de Tiny Tacticians",
        "description": "Publica un nuevo tablero jugable de Tiny Tacticians",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-install",
    "onAppUpgrade": "/internal/on-install"
  },
  "scheduler": {
    "tasks": {
      "daily-rollover": {
        "endpoint": "/internal/cron/daily-rollover",
        "cron": "0 0 * * *"
      }
    }
  },
  "dev": {
    "subreddit": "tiny_tacticians_dev"
  }
}